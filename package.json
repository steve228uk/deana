{
  "name": "deana",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; vercel dev",
    "build": "bun run evidence:install && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "vercel:login": "vercel login",
    "vercel:link": "vercel link",
    "vercel:env": "vercel env pull .env.local",
    "evidence:install": "bun run scripts/installEvidencePack.ts",
    "evidence:check": "bun run scripts/installEvidencePack.ts --check"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "@ai-sdk/react": "^3.0.170",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.168",
    "fflate": "^0.8.2",
    "minisearch": "^7.1.2",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^26.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.6.3",
    "vercel": "^52.0.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
